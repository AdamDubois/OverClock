#include <Arduino.h>
#include <Adafruit_NeoPixel.h>
#include <stdint.h>

#define NEW_PISKEL_FRAME_COUNT 52
#define NEW_PISKEL_FRAME_WIDTH 32
#define NEW_PISKEL_FRAME_HEIGHT 8

// === Config matérielle ===
static const uint8_t W = NEW_PISKEL_FRAME_WIDTH;   // 32
static const uint8_t H = NEW_PISKEL_FRAME_HEIGHT;  // 8
static const uint16_t N = W * H;                   // 256

#define DATA_PIN 9   // adapte au GPIO de ton ESP32-C3
Adafruit_NeoPixel strip(N, DATA_PIN, NEO_GRB + NEO_KHZ800);

// Mapping conforme à ton dessin (serpentin par colonnes)
uint16_t XY(uint8_t x, uint8_t y) {
  if (x >= W || y >= H) return 0;
  if ((x & 1) == 0) return x * H + y;        // colonnes paires: haut->bas
  return x * H + (H - 1 - y);                // colonnes impaires: bas->haut
}

