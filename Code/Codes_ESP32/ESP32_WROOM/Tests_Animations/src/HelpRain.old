// --- Helpers Piskel -> NeoPixel ---
static inline uint8_t a32(uint32_t c) { return (uint8_t)((c >> 24) & 0xFF); }
static inline uint8_t r32(uint32_t c) { return (uint8_t)((c >> 16) & 0xFF); }
static inline uint8_t g32(uint32_t c) { return (uint8_t)((c >> 8) & 0xFF); }
static inline uint8_t b32(uint32_t c) { return (uint8_t)((c >> 0) & 0xFF); }

// Piskel export chez toi semble être en 0xAABBGGRR (ex: 0xff0000ff = rouge).
uint32_t piskelToNeoPixel(uint32_t c) {
  uint8_t a = (c >> 24) & 0xFF;
  if (a == 0) return 0;

  uint8_t b = (c >> 16) & 0xFF;
  uint8_t g = (c >>  8) & 0xFF;
  uint8_t r = (c >>  0) & 0xFF;

  return strip.Color(r, g, b);
}

// Affiche une frame en supposant que frameData est en "row-major": idx = y*W + x
void drawFrameRowMajor(const uint32_t *frameData) {
  for (uint8_t y = 0; y < H; y++) {
    for (uint8_t x = 0; x < W; x++) {
      uint16_t srcIdx = (uint16_t)y * W + x;
      uint16_t dstIdx = XY(x, y);
      strip.setPixelColor(dstIdx, piskelToNeoPixel(frameData[srcIdx]));
    }
  }
}

void setup() {
  strip.begin();
  strip.setBrightness(80);
  strip.show();
}

void loop() {
  static uint8_t frame = 0;
  static uint32_t last = 0;

  const uint16_t frameDelayMs = 120; // vitesse animation (ajuste)

  uint32_t now = millis();
  if (now - last >= frameDelayMs) {
    last = now;

    drawFrameRowMajor(new_piskel_data[frame]);
    strip.show();

    frame = (frame + 1) % NEW_PISKEL_FRAME_COUNT;
  }
}